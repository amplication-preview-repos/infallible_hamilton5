datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  createdAt DateTime        @default(now())
  errorMsg  String?
  id        String          @id @default(cuid())
  otpCode   String?
  password  String?
  phone     String?
  status    EnumTaskStatus?
  updatedAt DateTime        @updatedAt
}

enum EnumTaskStatus {
  Option1
}
